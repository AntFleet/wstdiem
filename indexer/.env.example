# wstDIEM v0.1.0-rc1 indexer — example environment configuration.
# Copy to .env, edit values, and never commit your real .env.

WSTDIEM_CHAIN_ID=8453
WSTDIEM_RPC_URL=https://mainnet.base.org
# Optional fallbacks, comma-separated:
# WSTDIEM_RPC_FALLBACK_URLS=https://base.publicnode.com,https://rpc.ankr.com/base
WSTDIEM_START_BLOCK=47000000
WSTDIEM_CONFIRMATIONS=2
WSTDIEM_POLL_INTERVAL_MS=2000
WSTDIEM_REORG_DEPTH=64
WSTDIEM_DB_PATH=./data/indexer.db
WSTDIEM_API_PORT=8080
WSTDIEM_API_HOST=127.0.0.1
WSTDIEM_LOG_LEVEL=info

# Deployment addresses (zero-address placeholders until deploy ceremony lands).
WSTDIEM_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
WSTDIEM_AUTHORIZATION_ADDRESS=0x0000000000000000000000000000000000000000
WSTDIEM_FORCE_EXIT_AUTHORIZER_ADDRESS=0x0000000000000000000000000000000000000000
WSTDIEM_EXECUTOR_V2_ADDRESS=0x0000000000000000000000000000000000000000
WSTDIEM_FORCE_EXIT_EXECUTOR_ADDRESS=0x0000000000000000000000000000000000000000
WSTDIEM_ANCHOR_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
WSTDIEM_FEE_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000
WSTDIEM_EMERGENCY_GUARDIAN_ADDRESS=0x0000000000000000000000000000000000000000
