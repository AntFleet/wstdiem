{
  "name": "@wstdiem/indexer",
  "version": "0.1.0",
  "description": "wstDIEM v0.1.0-rc1 indexer — consumes G12 events and anchor snapshots into a queryable SQLite store.",
  "type": "module",
  "private": true,
  "bin": {
    "wstdiem-indexer": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "better-sqlite3": "^11.10.0",
    "commander": "^13.1.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "viem": "^2.29.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
